# Staging template. Copy this file to .env.staging.local or another non-versioned file.
# Replace all placeholder secrets before any shared or persistent use.
# Never commit real staging secrets to the repository.
APP_NAME=ine_asturias_api
APP_VERSION=0.1.0-rc1
APP_ENV=staging
INE_BASE_URL=https://servicios.ine.es/wstempus/js/ES
CARTOCIUDAD_BASE_URL=https://www.cartociudad.es/geocoder/api/geocoder
IGN_ADMIN_SNAPSHOT_URL=
CATASTRO_BASE_URL=https://www.catastro.hacienda.gob.es
CATASTRO_TIMEOUT_SECONDS=20
CATASTRO_CACHE_TTL_SECONDS=604800
CATASTRO_URBANO_YEAR=
HTTP_TIMEOUT_SECONDS=15
POSTGRES_DB=ine_asturias
POSTGRES_USER=postgres
# OBLIGATORIO — nunca usar valores de ejemplo en entornos reales
POSTGRES_PASSWORD=
API_KEY=
POSTGRES_DSN=postgresql+asyncpg://postgres:${POSTGRES_PASSWORD}@db:5432/ine_asturias
POSTGRES_HOST_PORT=5434
ENABLE_CACHE=true
CACHE_TTL_SECONDS=300
PROVIDER_TOTAL_TIMEOUT_SECONDS=30
HTTP_RETRY_MAX_ATTEMPTS=3
HTTP_RETRY_BACKOFF_SECONDS=1
LOG_LEVEL=INFO
REDIS_HOST_PORT=6380
REDIS_URL=redis://redis:6379/0
API_HOST_PORT=8002
JOB_QUEUE_NAME=ine_jobs
JOB_RESULT_TTL_SECONDS=86400
ANALYTICAL_SNAPSHOT_TTL_SECONDS=21600
TERRITORIAL_EXPORT_TTL_SECONDS=86400
MAX_CONCURRENT_TABLE_FETCHES=3
MAX_CONCURRENT_SERIES_FETCHES=5
INE_SERIES_DIRECT_MAX_SERIES=5000
INE_SERIES_DIRECT_MAX_ERRORS_TO_PERSIST=100
INE_RAW_PAYLOAD_MAX_BYTES=1048576
INE_TABLE_BACKGROUND_ONLY_THRESHOLD=100000
INE_TABLE_ABORT_THRESHOLD=250000
INE_INCIDENT_FAILURE_STREAK_THRESHOLD=2
INE_INCIDENT_NO_DATA_STREAK_THRESHOLD=3
INE_INCIDENT_WARNING_COUNT_THRESHOLD=5
HEAVY_INE_OPERATIONS=["23"]
RATE_LIMIT_ENABLED=true
PROVIDER_CIRCUIT_BREAKER_FAILURES=5
PROVIDER_CIRCUIT_BREAKER_RECOVERY_SECONDS=30
PROVIDER_CIRCUIT_BREAKER_HALF_OPEN_SAMPLE_SIZE=5
PROVIDER_CIRCUIT_BREAKER_SUCCESS_THRESHOLD=0.8
WORKER_HEARTBEAT_TTL_SECONDS=60
WORKER_METRICS_PORT=9001
WORKER_METRICS_URL=http://worker:9001/metrics
SCHEDULED_INE_OPERATIONS=["71","22","33"]
SCHEDULED_TERRITORIAL_SYNC_ENABLED=true
JOB_STORE_BACKEND=redis
TRUSTED_HOST_HEADER=X-Forwarded-For
