# Local development template.
# Copy to .env and fill in the values before running docker compose up.
#   cp .env.local.example .env
#
# .env is gitignored — never commit real secrets.

APP_ENV=local

# --- OBLIGATORIO: secretos sin default en docker-compose ---
POSTGRES_PASSWORD=change-me-local
API_KEY=change-me-local-api-key
POSTGRES_DSN=postgresql+asyncpg://postgres:change-me-local@db:5432/ine_asturias

# --- Opcionales: los defaults de docker-compose ya funcionan ---
# POSTGRES_DB=ine_asturias
# POSTGRES_USER=postgres
# POSTGRES_HOST_PORT=5433
# REDIS_HOST_PORT=6379
# API_HOST_PORT=8001
# LOG_LEVEL=INFO
# ENABLE_CACHE=true
# CACHE_TTL_SECONDS=300
