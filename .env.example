# Local development defaults for Docker Compose.
# Copy this file to .env.local or .env and use it only for desarrollo/local.
# Never commit real secrets derived from this file.
# Do not reuse this file as staging configuration.
APP_NAME=ine_asturias_api
APP_VERSION=0.1.0-rc1
APP_ENV=local
INE_BASE_URL=https://servicios.ine.es/wstempus/js/ES
CARTOCIUDAD_BASE_URL=https://www.cartociudad.es/geocoder/api/geocoder
HTTP_TIMEOUT_SECONDS=15
POSTGRES_DB=ine_asturias
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST_PORT=5433
POSTGRES_DSN=postgresql+asyncpg://postgres:postgres@db:5432/ine_asturias
ENABLE_CACHE=true
CACHE_TTL_SECONDS=300
API_KEY=
LOG_LEVEL=INFO
REDIS_HOST_PORT=6379
REDIS_URL=redis://redis:6379/0
API_HOST_PORT=8001
JOB_QUEUE_NAME=ine_jobs
JOB_RESULT_TTL_SECONDS=86400
ANALYTICAL_SNAPSHOT_TTL_SECONDS=21600
MAX_CONCURRENT_TABLE_FETCHES=3
WORKER_HEARTBEAT_TTL_SECONDS=60
WORKER_METRICS_PORT=9001
WORKER_METRICS_URL=http://worker:9001/metrics
